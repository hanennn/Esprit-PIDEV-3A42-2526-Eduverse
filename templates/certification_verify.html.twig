{% extends 'base.html.twig' %}

{% block title %}Vérification du Certificat{% endblock %}

{% block body %}
<div class="container py-5">

  <div class="card shadow-lg border-0">
    <div class="card-body p-5">

      {% if certification is not null %}

        <div class="text-center mb-4">
          <h2 class="text-success">✅ Certificat VALIDE</h2>
          <p class="text-muted">Ce certificat est authentique et vérifié par le système.</p>
        </div>

        <hr>

        <div class="row mt-4">
          <div class="col-md-6">
            <p><strong>👤 Nom :</strong><br>
              {{ certification.user.prenom }} {{ certification.user.nom }}
            </p>

            <p><strong>📧 Email :</strong><br>
              {{ certification.user.email }}
            </p>
          </div>

          <div class="col-md-6">
            <p><strong>📚 Quiz :</strong><br>
              {{ certification.quiz.titre }}
            </p>

            <p><strong>🏆 Badge :</strong><br>
              {{ certification.tentative.badge }}
            </p>
          </div>
        </div>

        <hr>

        <p><strong>📊 Score :</strong> {{ certification.tentative.scoreObtenu }} / 20</p>
        <p><strong>📅 Date d'émission :</strong> {{ certification.dateEmission|date('d/m/Y H:i') }}</p>
        <p><strong>🆔 ID Certificat :</strong> {{ certification.id }}</p>

        {% if aiSummary %}
          <hr>
          <h5 class="mb-2">📝 Résumé IA (officiel)</h5>
          <p class="text-muted mb-0">{{ aiSummary }}</p>
        {% endif %}

      {% else %}

        <div class="text-center">
          <h2 class="text-danger">❌ Certificat INVALIDE</h2>
          <p class="text-muted">
            Le lien est incorrect ou le certificat a été falsifié.
          </p>
        </div>

      {% endif %}

    </div>
  </div>

</div>
{% endblock %}
