{% extends 'base.html.twig' %}

{% block title %}Événements Eduverse{% endblock %}

{% block body %}
<!-- page title -->
<section class="page-title-section overlay" data-background="{{ asset('images/backgrounds/page-title.jpg') }}">
  <div class="container">
    <div class="row">
      <div class="col-md-8">
        <ul class="list-inline custom-breadcrumb">
          <li class="list-inline-item"><a class="h2 text-primary font-secondary" href="{{ path('app_event_list') }}">Événements</a></li>
          <li class="list-inline-item text-white h3 font-secondary"></li>
        </ul>
        <p class="text-lighten">Découvrez et inscrivez-vous à nos webinaires, ateliers et challenges pour enrichir votre parcours.</p>
      </div>
      <div class="col-md-4 text-right d-flex align-items-center justify-content-end">
        {% if app.user %}
          <a href="{{ path('app_mes_inscriptions') }}" class="btn btn-primary rounded-0"><i class="ti-calendar mr-2"></i>Mes Inscriptions</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>
<!-- /page title -->

<section class="section">
  <div class="container">
    <div class="row">
      {% for event in events %}
      <div class="col-lg-4 col-sm-6 mb-5">
        <div class="card p-0 border-primary rounded-0 hover-shadow h-100">
          <div style="height: 200px; overflow: hidden; position: relative;">
             <img class="card-img-top rounded-0" src="{{ event.image ? asset(event.image) : asset('images/courses/course-1.jpg') }}" alt="{{ event.titre }}" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;">
             <div style="position: absolute; top: 15px; left: 15px;">
                {% if event.type == 'webinaire' %}
                    <span class="badge badge-primary px-3 py-2" style="border-radius: 0;">Webinaire</span>
                {% elseif event.type == 'atelier' %}
                    <span class="badge badge-info px-3 py-2" style="border-radius: 0;" style="background-color: #7048e8;">Atelier</span>
                {% elseif event.type == 'challenge' %}
                    <span class="badge badge-warning px-3 py-2" style="border-radius: 0;">Challenge</span>
                {% endif %}
             </div>
          </div>
          <div class="card-body d-flex flex-column">
            <ul class="list-inline mb-3">
              <li class="list-inline-item mr-3"><i class="ti-calendar mr-2 text-primary"></i>{{ event.date|date('d M Y') }}</li>
              <li class="list-inline-item"><i class="ti-time mr-2 text-primary"></i>{{ event.heureDeb|date('H:i') }}</li>
            </ul>
            <a href="{{ path('app_event_details', {'id': event.id}) }}">
              <h4 class="card-title text-dark font-weight-bold mb-3">{{ event.titre }}</h4>
            </a>
            <p class="card-text mb-4 text-muted">{{ event.description|striptags|slice(0, 100) }}...</p>
            <div class="mt-auto">
                <a href="{{ path('app_event_details', {'id': event.id}) }}" class="btn btn-primary btn-sm w-100">Voir Détails</a>
            </div>
          </div>
        </div>
      </div>
      {% else %}
        <div class="col-12 text-center py-5">
            <i class="ti-calendar mb-3 text-muted" style="font-size: 3rem;"></i>
            <h3 class="text-muted">Aucun événement prévu pour le moment.</h3>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}
