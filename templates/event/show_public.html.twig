{% extends 'base.html.twig' %}

{% block title %}Détails Événement - {{ event.titre }}{% endblock %}

{% block body %}
<!-- page title -->
<section class="page-title-section overlay" data-background="{{ asset('images/backgrounds/page-title.jpg') }}">
  <div class="container">
    <div class="row">
      <div class="col-md-8">
        <ul class="list-inline custom-breadcrumb">
          <li class="list-inline-item"><a class="h2 text-primary font-secondary" href="{{ path('app_event_list') }}">Événements</a></li>
          <li class="list-inline-item text-white h3 font-secondary nasted">{{ event.titre }}</li>
        </ul>
      </div>
    </div>
  </div>
</section>
<!-- /page title -->

<section class="section">
  <div class="container">
    <div class="row">
      <!-- Main Content -->
      <div class="col-lg-8">
        <div class="card border-primary rounded-0 hover-shadow mb-5">
          <img class="card-img-top rounded-0" src="{{ event.image ? asset(event.image) : asset('images/courses/course-1.jpg') }}" alt="{{ event.titre }}" style="max-height: 450px; object-fit: cover;">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="font-weight-bold mb-0">{{ event.titre }}</h2>
                {% if event.type == 'webinaire' %}
                    <span class="badge badge-primary px-3 py-2">Webinaire</span>
                {% elseif event.type == 'atelier' %}
                    <span class="badge badge-info px-3 py-2">Atelier</span>
                {% elseif event.type == 'challenge' %}
                    <span class="badge badge-warning px-3 py-2">Challenge</span>
                {% endif %}
            </div>
            
            <div class="d-flex align-items-center mb-4 text-muted">
                <div class="mr-4">
                    <i class="ti-calendar text-primary mr-2"></i> {{ event.date|date('d M Y') }}
                </div>
                <div class="mr-4">
                    <i class="ti-time text-primary mr-2"></i> {{ event.heureDeb|date('H:i') }} - {{ event.heureFin|date('H:i') }}
                </div>
            </div>

            <div class="content">
                <h4 class="mb-3">À propos de cet événement</h4>
                <p style="white-space: pre-line; line-height: 1.8; color: #5c5c77;">{{ event.description }}</p>

                {% if event.type == 'challenge' and event.niveau %}
                    <div class="mt-4 p-3 bg-light" style="border-left: 4px solid #ffbc3b;">
                        <span class="font-weight-bold">Niveau requis :</span> {{ event.niveau|capitalize }}
                    </div>
                {% endif %}
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="col-lg-4">
        <div class="card border-primary rounded-0 hover-shadow p-4 mb-4">
            <h4 class="mb-3">Informations Clés</h4>
            <ul class="list-unstyled mb-4">
                <li class="mb-3 border-bottom pb-2">
                    <span class="text-muted d-block small">Type d'activité :</span>
                    <span class="font-weight-bold">{{ event.type|capitalize }}</span>
                </li>
                <li class="mb-3 border-bottom pb-2">
                    <span class="text-muted d-block small">Date :</span>
                    <span class="font-weight-bold">{{ event.date|date('l d F Y') }}</span>
                </li>
                <li class="mb-3">
                    <span class="text-muted d-block small">Horaire :</span>
                    <span class="font-weight-bold">{{ event.heureDeb|date('H:i') }} à {{ event.heureFin|date('H:i') }}</span>
                </li>
            </ul>

            {% if isRegistered %}
                <div class="alert alert-success text-center">
                    <i class="ti-check-box mr-2"></i>Vous êtes déjà inscrit
                </div>
                <a href="{{ path('app_mes_inscriptions') }}" class="btn btn-outline-primary btn-block">Voir mes inscriptions</a>
            {% else %}
                <a href="{{ path('app_event_register', {'id': event.id}) }}" class="btn btn-primary btn-block">S'inscrire maintenant</a>
            {% endif %}
        </div>

        <div class="card border-primary rounded-0 hover-shadow p-4">
            <h4 class="mb-3">Besoin d'aide ?</h4>
            <p>Pour toute question sur l'événement, contactez notre équipe support.</p>
            <a href="#" class="text-primary font-weight-bold">Formulaire de contact</a>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
