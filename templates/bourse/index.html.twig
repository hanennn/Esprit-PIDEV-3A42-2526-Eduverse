{% extends 'base.html.twig' %}

{% block title %}Nos Bourses{% endblock %}

{% block body %}
<section class="page-title-section overlay" data-background="{{ asset('images/backgrounds/page-title.jpg') }}">
  <div class="container">
    <div class="row">
      <div class="col-md-8">
        <ul class="list-inline custom-breadcrumb">
          <li class="list-inline-item"><a class="h2 text-primary font-secondary" href="@@page-link">Nos Bourses</a></li>
          <li class="list-inline-item text-white h3 font-secondary @@nasted"></li>
        </ul>
        <p class="text-lighten">Découvrez nos offres de bourses et opportunités de financement pour vos études.</p>
      </div>
      <div class="col-md-4 text-right d-flex align-items-center justify-content-end">
        {% if app.user %}
          <a href="{{ path('app_mes_candidatures') }}" class="btn btn-primary rounded-0"><i class="ti-files mr-2"></i>Mes Candidatures</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="row">
      {% for bourse in bourses %}
      <div class="col-lg-4 col-sm-6 mb-5">
        <div class="card p-0 border-primary rounded-0 hover-shadow h-100">
          <div style="height: 200px; overflow: hidden;">
             <img class="card-img-top rounded-0" src="{{ bourse.image ? asset(bourse.image) : asset('images/courses/course-1.jpg') }}" alt="{{ bourse.titre }}" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;">
          </div>
          <div class="card-body d-flex flex-column">
            <ul class="list-inline mb-3">
              <li class="list-inline-item mr-3"><i class="ti-calendar mr-2 text-primary"></i>{{ bourse.dateAttribution|date('d M Y') }}</li>
              <li class="list-inline-item"><i class="ti-money mr-2 text-primary"></i>{{ bourse.montant|number_format(0, ',', ' ') }} DT</li>
            </ul>
            <a href="{{ path('app_bourse_details_student', {'id': bourse.id}) }}">
              <h4 class="card-title text-dark font-weight-bold mb-3">{{ bourse.titre }}</h4>
            </a>
            <p class="card-text mb-4 text-muted">{{ bourse.description|striptags|slice(0, 100) }}...</p>
            <div class="mt-auto">
                <a href="{{ path('app_bourse_details_student', {'id': bourse.id}) }}" class="btn btn-primary btn-sm w-100">Voir Détails</a>
            </div>
          </div>
        </div>
      </div>
      {% else %}
        <div class="col-12 text-center py-5">
            <i class="ti-folder mb-3 text-muted" style="font-size: 3rem;"></i>
            <h3 class="text-muted">Aucune bourse disponible pour le moment.</h3>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}
