{% extends 'base.html.twig' %}

{% block title %}Postuler - {{ bourse.titre }}{% endblock %}

{% block body %}
<section class="page-title-section overlay" data-background="{{ asset('images/backgrounds/page-title.jpg') }}">
  <div class="container">
    <div class="row">
      <div class="col-md-8">
        <ul class="list-inline custom-breadcrumb">
          <li class="list-inline-item"><a class="h2 text-primary font-secondary" href="{{ path('app_bourse_list') }}">Bourses</a></li>
          <li class="list-inline-item text-white h3 font-secondary nasted">{{ bourse.titre }}</li>
        </ul>
        <p class="text-lighten">Formulaire de candidature.</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card border-primary rounded-0 hover-shadow">
          <div class="card-body p-5">
            <h3 class="mb-4 text-center">Formulaire de Demande</h3>
            
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="ti-check-box mr-2"></i>{{ message }}
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            {% endfor %}
            
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="ti-alert mr-2"></i>{{ message }}
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            {% endfor %}
            
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            <div class="form-group mb-4">
                <label class="font-weight-bold text-dark">Niveau d'études</label>
                {{ form_widget(form.niveauEtudes, {'attr': {'class': 'form-control rounded-0', 'style': 'height: 50px;'}}) }}
                {% if form.niveauEtudes.vars.errors|length > 0 %}
                    <div class="text-danger mt-1">
                        {{ form_errors(form.niveauEtudes) }}
                    </div>
                {% endif %}
            </div>

            <div class="form-group mb-4">
                <label class="font-weight-bold text-dark">Lettre de Motivation (PDF)</label>
                {{ form_widget(form.lettreMotivation, {'attr': {'class': 'form-control-file border p-2 w-100'}}) }}
                <small class="text-muted d-block mt-2">Format accepté : PDF uniquement. Taille max : 10Mo.</small>
                {% if form.lettreMotivation.vars.errors|length > 0 %}
                    <div class="text-danger mt-1">
                        {{ form_errors(form.lettreMotivation) }}
                    </div>
                {% endif %}
            </div>

            <div class="form-group mb-5">
                <label class="font-weight-bold text-dark">Note / Description (Optionnel)</label>
                {{ form_widget(form.note, {'attr': {'class': 'form-control rounded-0'}}) }}
                <small class="text-muted d-block mt-2">Ajoutez toute information complémentaire concernant votre candidature.</small>
                {% if form.note.vars.errors|length > 0 %}
                    <div class="text-danger mt-1">
                        {{ form_errors(form.note) }}
                    </div>
                {% endif %}
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-primary btn-lg px-5">Envoyer ma candidature</button>
                <a href="{{ path('app_bourse_details_student', {'id': bourse.id}) }}" class="btn btn-outline-secondary btn-lg px-5 ml-3">Annuler</a>
            </div>

            {{ form_end(form) }}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
