{% extends 'base.html.twig' %}

{% block title %}Détails de la Bourse{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('css/style.css') }}" rel="stylesheet">
    <style>
        .navigation, header, .header, .top-header, nav.navbar { display: none !important; }
        body { margin: 0 !important; padding: 0 !important; overflow-x: hidden; background: #f8f9fa; }
        .admin-sidebar { position: fixed; left: 0; top: 0; width: 250px; height: 100vh; background: #2c3e50; color: white; z-index: 1000; padding-top: 20px; transition: all 0.3s; overflow-y: auto;}
        .sidebar-menu { list-style: none; padding: 0; margin: 20px 0; }
        .sidebar-menu a { display: flex; align-items: center; padding: 15px 20px; color: rgba(255, 255, 255, 0.7); text-decoration: none; border-left: 3px solid transparent; transition: all 0.3s; }
        .sidebar-menu a:hover, .sidebar-menu a.active { background: rgba(255, 188, 59, 0.1); color: #ffbc3b; border-left: 3px solid #ffbc3b; }
        .sidebar-menu a i { margin-right: 15px; font-size: 18px; min-width: 20px; }
        .admin-content { margin-left: 250px; padding: 30px; min-height: 100vh; background: #f8f9fa; transition: all 0.3s; }
        .dashboard-card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03); margin-bottom: 30px; border: 1px solid #edf2f9; }
        .page-header { margin-bottom: 25px; display: flex; align-items: center; }
        .back-btn { margin-right: 15px; color: #6c757d; font-size: 20px; text-decoration: none; transition: all 0.2s; background: white; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 50%; box-shadow: 0 2px 5px rgba(0,0,0,0.05); border: 1px solid #eef0f8; }
        .back-btn:hover { color: #ffbc3b; transform: translateX(-3px); box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .page-title h2 { font-size: 24px; font-weight: 700; color: #2c3e50; margin: 0; }
        .detail-label { font-size: 12px; font-weight: 700; text-transform: uppercase; color: #6c757d; letter-spacing: 0.5px; margin-bottom: 5px; }
        .detail-value { font-size: 16px; color: #2c3e50; font-weight: 500; margin-bottom: 20px; }
        .bourse-image { width: 100%; height: 300px; object-fit: cover; border-radius: 12px; margin-bottom: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    </style>
{% endblock %}

{% block body %}
<div class="admin-sidebar">
    <div class="sidebar-toggle" onclick="toggleSidebar()" style="text-align: center; padding: 20px; font-size: 24px;">
        <i class="ti-menu"></i>
    </div>
    <ul class="sidebar-menu">
        <li><a href="{{ path('app_profile') }}"><i class="ti-dashboard"></i><span>Tableau de Bord</span></a></li>
        <li><a href="{{ path('app_bourse_index') }}" class="active"><i class="ti-medall"></i><span>Bourses</span></a></li>
    </ul>
</div>

<div class="admin-content">
    <div class="page-header">
        <a href="{{ path('app_bourse_index') }}" class="back-btn"><i class="ti-arrow-left"></i></a>
        <div class="page-title">
            <h2>Détails de la Bourse</h2>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="dashboard-card">
                {% if bourse.image %}
                    <img src="{{ bourse.image }}" class="bourse-image" alt="{{ bourse.titre }}">
                {% endif %}

                <div class="row">
                    <div class="col-md-8">
                        <div class="detail-label">Titre</div>
                        <div class="detail-value h4">{{ bourse.titre }}</div>
                        
                        <div class="detail-label">Description</div>
                        <div class="detail-value" style="white-space: pre-line; line-height: 1.6;">{{ bourse.description }}</div>
                    </div>
                    <div class="col-md-4 pl-md-5" style="border-left: 1px solid #f0f0f0;">
                        <div class="detail-label">Montant</div>
                        <div class="detail-value text-primary font-weight-bold" style="font-size: 24px;">{{ bourse.montant|number_format(0, ',', ' ') }} DT</div>
                        
                        <div class="detail-label">Date d'Attribution</div>
                        <div class="detail-value"><i class="ti-calendar mr-2 text-success"></i>{{ bourse.dateAttribution ? bourse.dateAttribution|date('d/m/Y H:i') : '-' }}</div>
                        
                        <div class="detail-label">Date d'Expiration</div>
                        <div class="detail-value"><i class="ti-calendar mr-2 text-danger"></i>{{ bourse.dateFin ? bourse.dateFin|date('d/m/Y H:i') : '-' }}</div>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4 pt-4 border-top">
                    <a href="{{ path('app_bourse_edit', {'id': bourse.id}) }}" class="btn btn-warning text-white mr-2">
                        <i class="ti-pencil mr-2"></i>Modifier
                    </a>
                    
                    {{ include('bourse_admin/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
