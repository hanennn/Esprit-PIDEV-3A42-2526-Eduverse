{# ── AI Interview Report Block ──
   Include this in bourse_admin/show_demande.html.twig #}

{% if demande.analyseInterview %}
    {% set analyse = demande.analyseInterview %}

    <div class="dashboard-card" style="border-left: 4px solid #2E86AB;">
        <h4 style="color: #2c3e50; font-size: 18px; margin-bottom: 5px;">
            <i class="ti-pulse mr-2" style="color: #2E86AB;"></i>Rapport IA — Interview Vocale
        </h4>
        <p class="text-muted mb-4" style="font-size: 12px;">
            Réalisée le {{ analyse.dateInterview|date('d/m/Y à H:i') }}
        </p>

        {# Global profile #}
        <div class="p-3 mb-4" style="background:#EAF2FB; border-left: 4px solid #1A3A5C; border-radius: 4px;">
            <strong>Profil IA :</strong>
            <span class="ml-2">{{ analyse.profilGlobal }}</span>
        </div>

        <div class="row">
            {# Emotion scores #}
            <div class="col-md-6 mb-3">
                <h6 class="font-weight-bold mb-3">Scores émotionnels</h6>

                {% set scores = [
                    {'label': 'Déterminé', 'val': analyse.scoreDetermine, 'color': '#1A3A5C'},
                    {'label': 'Motivé',    'val': analyse.scoreMotive,    'color': '#1A5C2A'},
                    {'label': 'Confiant',  'val': analyse.scoreConfiant,  'color': '#0D6B6B'},
                    {'label': 'Anxieux',   'val': analyse.scoreAnxieux,   'color': '#7A3B00'},
                    {'label': 'Hésitant',  'val': analyse.scoreHesitant,  'color': '#4A5568'},
                ] %}

                {% for s in scores %}
                    {% if s.val is not null %}
                        {% set pct = (s.val * 100)|round %}
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span style="font-size: 13px;">{{ s.label }}</span>
                                <strong style="font-size: 13px;">{{ pct }}%</strong>
                            </div>
                            <div class="progress" style="height: 12px; border-radius: 6px;">
                                <div class="progress-bar"
                                     style="width:{{ pct }}%; background:{{ s.color }}; border-radius: 6px;">
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>

            {# Audio features #}
            <div class="col-md-6 mb-3">
                <h6 class="font-weight-bold mb-3">Analyse vocale</h6>
                <table class="table table-sm table-bordered" style="font-size: 13px;">
                    <tbody>
                        <tr>
                            <td class="text-muted">Débit de parole</td>
                            <td>
                                <strong>{{ analyse.debitParole ?? '-' }} mots/min</strong>
                                {% if analyse.debitParole %}
                                    {% if analyse.debitParole > 160 %}
                                        <span class="badge badge-warning ml-1">Rapide</span>
                                    {% elseif analyse.debitParole < 100 %}
                                        <span class="badge badge-secondary ml-1">Lent</span>
                                    {% else %}
                                        <span class="badge badge-success ml-1">Normal</span>
                                    {% endif %}
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Hésitations</td>
                            <td>
                                <strong>{{ analyse.tauxHesitations ?? '-' }}%</strong>
                                {% if analyse.tauxHesitations is not null %}
                                    {% if analyse.tauxHesitations > 20 %}
                                        <span class="badge badge-warning ml-1">Élevé</span>
                                    {% else %}
                                        <span class="badge badge-success ml-1">Faible</span>
                                    {% endif %}
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Énergie vocale</td>
                            <td><strong>{{ analyse.energieVocale|default('-')|capitalize }}</strong></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        {# Transcription #}
        <div class="mt-2">
            <h6 class="font-weight-bold">Transcription</h6>
            <div class="p-3" style="background:#F8F9FA; border-left: 4px solid #2E86AB; border-radius: 4px;">
                <p class="font-italic text-muted mb-0" style="font-size: 13px;">
                    "{{ analyse.transcription }}"
                </p>
            </div>
        </div>

        {# Recommendation #}
        <div class="p-3 mt-3" style="background:#FEF6EA; border-left: 4px solid #7A3B00; border-radius: 4px;">
            <strong>Recommandation IA :</strong>
            <span class="ml-2">{{ analyse.recommandation }}</span>
        </div>
    </div>

{% else %}
    <div class="dashboard-card" style="border-left: 4px solid #6c757d;">
        <p class="text-muted mb-0">
            <i class="ti-microphone mr-2"></i>Aucune interview IA réalisée pour cette candidature.
        </p>
    </div>
{% endif %}
