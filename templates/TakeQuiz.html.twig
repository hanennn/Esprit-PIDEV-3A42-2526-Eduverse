{% extends 'base.html.twig' %}

{% block title %}{{ quiz.titre }}{% endblock %}

{% block body %}
<div class="container mt-4">

    <h2 class="text-center mb-3">📝 {{ quiz.titre }}</h2>

    {# TIMER #}
    <div class="alert alert-info text-center fs-4">
        ⏱️ Temps restant : <strong><span id="timer"></span></strong>
    </div>

    <form method="post" id="quizForm">

        {% for question in questions %}
            <div class="card mb-4 shadow-sm">
                <div class="card-body">

                    <h5>
                        {{ loop.index }}. {{ question.question }}
                        <span class="badge bg-primary">{{ question.points }} pts</span>
                    </h5>

                    <hr>

                    {% for reponse in question.reponses %}
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="radio"
                                   name="question_{{ question.id }}"
                                   value="{{ loop.index0 }}"
                                   id="q{{ question.id }}_{{ loop.index0 }}">
                            <label class="form-check-label" for="q{{ question.id }}_{{ loop.index0 }}">
                                {{ reponse.texte }}
                            </label>
                        </div>
                    {% endfor %}

                </div>
            </div>
        {% endfor %}

        <div class="text-center">
            <button type="submit" class="btn btn-success btn-lg">
                ✅ Soumettre le quiz
            </button>
        </div>

    </form>

    {# Affichage score simple sous le quiz #}
    {% if score is not null %}
        <div class="alert alert-success text-center mt-4 fs-4">
            🎯 Votre score :
            <strong>{{ score }} / {{ totalPoints }}</strong>
        </div>
    {% endif %}

</div>

{# ================= MODAL RESULT ================= #}
{% if showResult %}
<!-- Modal for the result -->
<div class="modal fade" id="resultModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    {% if score >= (totalPoints / 2) %}
                        🎉 Félicitations !
                    {% else %}
                        ❌ Dommage !
                    {% endif %}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <div class="fs-1 mb-2">
                    {% if score >= (totalPoints / 2) %}
                        😃
                    {% else %}
                        😢
                    {% endif %}
                </div>

                <div class="fs-5 fw-bold">
                    Votre score : {{ score }} / {{ totalPoints }}
                </div>

                {% if score < (totalPoints / 2) %}
                    <div class="alert alert-warning mt-3 text-start">
                        <h6 class="mb-2">📌 Conseils</h6>
                        <ul class="mb-0">
                            <li>Relisez le cours et notez les points importants.</li>
                            <li>Refaites des exercices avant de retenter.</li>
                            <li>Revenez plus fort 💪</li>
                        </ul>
                    </div>
                {% endif %}
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>

        </div>
    </div>
</div>
{% endif %}
{# ================= TIMER JS ================= #}
{# CHEAT DETECTOR UI #}
<div id="cheatOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 9999; color: white; text-align: center; padding-top: 20%;">
    <h1 style="color: #ff4444; font-size: 3rem; margin-bottom: 20px;">🚫 EXAMEN BLOQUÉ</h1>
    <p style="font-size: 1.5rem;">Tentative de triche détectée à plusieurs reprises.</p>
    <p>Votre session a été interrompue. Veuillez contacter l'administration.</p>
    <div class="mt-4">
        <a href="{{ path('app_profile') }}" class="btn btn-outline-light btn-lg">Retour au profil</a>
    </div>
</div>

{# Hidden video for landmark detection (now visible for debug) #}
<div id="debugCamera" style="position: fixed; bottom: 20px; right: 20px; width: 300px; border: 3px solid #666; border-radius: 10px; overflow: hidden; background: black; z-index: 1000; box-shadow: 0 5px 15px rgba(0,0,0,0.5);">
    <div style="background: #333; color: white; padding: 5px 10px; font-size: 0.8rem; display: flex; justify-content: space-between;">
        <span>🔍 Debug AI Monitor</span>
        <span id="strikeBadge" class="badge bg-success">Strikes: 0/2</span>
    </div>
    <div style="position: relative; width: 300px; height: 225px;">
        <video id="webcam" style="width: 100%; height: 100%; object-fit: cover;" autoplay playsinline></video>
        <canvas id="output_canvas" style="position: absolute; left: 0; top: 0; width: 100%; height: 100%; pointer-events: none;"></canvas>
        <div id="ai_status" style="position: absolute; bottom: 5px; left: 10px; color: #00ff00; font-family: monospace; font-size: 0.75rem; text-shadow: 1px 1px 1px black;">
            Initializing AI...
        </div>
    </div>
</div>

<script type="module">
    import { FaceLandmarker, FilesetResolver } from "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.3";

    document.addEventListener("DOMContentLoaded", function () {
        // --- TIMER LOGIC ---
        let minutes = {{ quiz.duree|default(0) }};
        let seconds = 0;
        const timerElement = document.getElementById("timer");

        function updateTimer() {
            if (!timerElement) return;
            if (minutes === 0 && seconds === 0) {
                document.getElementById("quizForm").submit();
                return;
            }
            if (seconds === 0) { minutes--; seconds = 59; } else { seconds--; }
            timerElement.textContent = String(minutes).padStart(2, '0') + ":" + String(seconds).padStart(2, '0');
        }
        updateTimer();
        setInterval(updateTimer, 1000);

        {% if showResult %}
            const modalEl = document.getElementById('resultModal');
            if (modalEl) { new bootstrap.Modal(modalEl).show(); }
        {% endif %}

        // --- CHEAT DETECTOR LOGIC ---
        let faceLandmarker;
        let sequenceBuffer = [];
        const video = document.getElementById("webcam");
        const canvas = document.getElementById("output_canvas");
        const ctx = canvas.getContext("2d");
        const statusEl = document.getElementById("ai_status");
        const strikeBadge = document.getElementById("strikeBadge");
        const WINDOW_SIZE = 90;

        async function initializeFaceLandmarker() {
            statusEl.innerText = "Reseting session...";
            fetch("{{ path('app_quiz_cheat_reset') }}", { method: 'POST' });

            try {
                const vision = await FilesetResolver.forVisionTasks(
                    "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.3/wasm"
                );
                faceLandmarker = await FaceLandmarker.createFromOptions(vision, {
                    baseOptions: {
                        modelAssetPath: `https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task`,
                        delegate: "GPU"
                    },
                    outputFaceBlendshapes: true,
                    runningMode: "IMAGE",
                    numFaces: 1
                });
                statusEl.innerText = "Model loaded. Starting cam...";
                startWebcam();
            } catch (e) {
                console.error("Mediapipe init failed", e);
                statusEl.innerText = "Init Failed: " + e.message;
                statusEl.style.color = "#ff4444";
            }
        }

        function startWebcam() {
            navigator.mediaDevices.getUserMedia({ video: true }).then((stream) => {
                video.srcObject = stream;
                video.addEventListener("loadeddata", () => {
                    canvas.width = video.videoWidth;
                    canvas.height = video.videoHeight;
                    statusEl.innerText = "Scanning Eye Data...";
                    predictWebcam();
                });
            }).catch(err => {
                statusEl.innerText = "Camera Access Denied";
                statusEl.style.color = "#ff4444";
            });
        }

        async function predictWebcam() {
            if (!faceLandmarker) return;
            
            const results = faceLandmarker.detect(video);
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            if (results.faceLandmarks && results.faceLandmarks.length > 0) {
                const landmarks = results.faceLandmarks[0];
                const leftIris = landmarks[468];  
                const rightIris = landmarks[473];

                // Draw points for debug
                ctx.fillStyle = "#00ff00";
                ctx.beginPath();
                ctx.arc(leftIris.x * canvas.width, leftIris.y * canvas.height, 4, 0, 2 * Math.PI);
                ctx.arc(rightIris.x * canvas.width, rightIris.y * canvas.height, 4, 0, 2 * Math.PI);
                ctx.fill();

                sequenceBuffer.push([leftIris.x, leftIris.y, rightIris.x, rightIris.y]);
                statusEl.innerText = `Analyzing: ${sequenceBuffer.length}/${WINDOW_SIZE}`;
                statusEl.style.color = "#00ff00";

                if (sequenceBuffer.length >= WINDOW_SIZE) {
                    const currentSequence = [...sequenceBuffer];
                    sequenceBuffer = []; 
                    checkCheat(currentSequence);
                }
            } else {
                statusEl.innerText = "No Face Detected ⚠️";
                statusEl.style.color = "#ffff00";
            }
            
            if (!{{ showResult ? 'true' : 'false' }}) {
                requestAnimationFrame(predictWebcam);
            }
        }

        async function checkCheat(sequence) {
            statusEl.innerText = "Querying AI... 🧠";
            statusEl.style.color = "#00bfff";

            try {
                const response = await fetch("{{ path('app_quiz_cheat_check') }}", {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sequence: sequence })
                });
                const data = await response.json();
                console.log("AI Result:", data);
                
                if (!data.success) {
                    statusEl.innerText = "AI Error: " + (data.error || "Unknown");
                    statusEl.style.color = "#ff4444";
                    return;
                }

                // Update HUD
                strikeBadge.innerText = `Strikes: ${data.count}/2`;
                if (data.count > 0) strikeBadge.className = "badge bg-danger";
                
                statusEl.innerText = `AI: ${data.label.toUpperCase()} (${(data.prob * 100).toFixed(1)}%)`;
                statusEl.style.color = data.label === 'cheat' ? "#ff4444" : "#00ff00";

                if (data.terminate) {
                    document.getElementById('cheatOverlay').style.display = 'block';
                    // Stop the timer and form
                    if (video.srcObject) {
                        video.srcObject.getTracks().forEach(track => track.stop());
                    }
                    clearInterval(updateTimer);
                }
            } catch (e) {
                console.error("AI Check failed", e);
                statusEl.innerText = "Connection Error";
                statusEl.style.color = "#ff4444";
            }
        }

        initializeFaceLandmarker();
    });
</script>

{% endblock %}