{% extends 'base.html.twig' %}

{% block title %}{{ quiz.titre }}{% endblock %}

{% block body %}
<div class="container mt-4">

    <h2 class="text-center mb-3">📝 {{ quiz.titre }}</h2>

    {# TIMER #}
    <div class="alert alert-info text-center fs-4">
        ⏱️ Temps restant : <strong><span id="timer"></span></strong>
    </div>

    <form method="post" id="quizForm">

        {% for question in questions %}
            <div class="card mb-4 shadow-sm">
                <div class="card-body">

                    <h5>
                        {{ loop.index }}. {{ question.question }}
                        <span class="badge bg-primary">{{ question.points }} pts</span>
                    </h5>

                    <hr>

                    {% for reponse in question.reponses %}
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="radio"
                                   name="question_{{ question.id }}"
                                   value="{{ loop.index0 }}"
                                   id="q{{ question.id }}_{{ loop.index0 }}">
                            <label class="form-check-label" for="q{{ question.id }}_{{ loop.index0 }}">
                                {{ reponse.texte }}
                            </label>
                        </div>
                    {% endfor %}

                </div>
            </div>
        {% endfor %}

        <div class="text-center">
            <button type="submit" class="btn btn-success btn-lg">
                ✅ Soumettre le quiz
            </button>
        </div>

    </form>

    {# Affichage score simple sous le quiz #}
    {% if score is not null %}
        <div class="alert alert-success text-center mt-4 fs-4">
            🎯 Votre score :
            <strong>{{ score }} / {{ totalPoints }}</strong>
        </div>
    {% endif %}

</div>

{# ================= MODAL RESULT ================= #}
{% if showResult %}
<!-- Modal for the result -->
<div class="modal fade" id="resultModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    {% if score >= (totalPoints / 2) %}
                        🎉 Félicitations !
                    {% else %}
                        ❌ Dommage !
                    {% endif %}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <div class="fs-1 mb-2">
                    {% if score >= (totalPoints / 2) %}
                        😃
                    {% else %}
                        😢
                    {% endif %}
                </div>

                <div class="fs-5 fw-bold">
                    Votre score : {{ score }} / {{ totalPoints }}
                </div>

                {% if score < (totalPoints / 2) %}
                    <div class="alert alert-warning mt-3 text-start">
                        <h6 class="mb-2">📌 Conseils</h6>
                        <ul class="mb-0">
                            <li>Relisez le cours et notez les points importants.</li>
                            <li>Refaites des exercices avant de retenter.</li>
                            <li>Revenez plus fort 💪</li>
                        </ul>
                    </div>
                {% endif %}
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>

        </div>
    </div>
</div>
{% endif %}
{# ================= TIMER JS ================= #}
<script>
document.addEventListener("DOMContentLoaded", function () {
    let minutes = {{ quiz.duree|default(0) }};
    let seconds = 0;

    const timerElement = document.getElementById("timer");

    function updateTimer() {
        if (!timerElement) return;

        if (minutes === 0 && seconds === 0) {
            document.getElementById("quizForm").submit();
            return;
        }

        if (seconds === 0) {
            minutes--;
            seconds = 59;
        } else {
            seconds--;
        }

        timerElement.textContent =
            String(minutes).padStart(2, '0') + ":" + String(seconds).padStart(2, '0');
    }

    updateTimer();
    setInterval(updateTimer, 1000);

    {# afficher modal après POST #}
    {% if showResult %}
        const modalEl = document.getElementById('resultModal');
        if (modalEl) {
            const modal = new bootstrap.Modal(modalEl);
            modal.show();
        }
    {% endif %}
});
</script>

{% endblock %}