{% block javascripts %}
    {{ parent() }}
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    
    <script>
    // Global chart instances
    var registrationsChartInstance = null;
    var bourseStatusChartInstance = null;
    var eventTypeChartInstance = null;
    
    function initStatsCharts() {
        // Bourse Status Chart
        var bourseCanvas = document.getElementById('bourseStatusChart');
        if (bourseCanvas && !bourseStatusChartInstance) {
            try {
                var bData = {{ (fullStats.bourses.chartData ?? {labels:[], data:[]})|json_encode|raw }};
                if (bData.labels.length > 0) {
                    bourseStatusChartInstance = new Chart(bourseCanvas, {
                        type: 'doughnut',
                        data: {
                            labels: bData.labels,
                            datasets: [{
                                data: bData.data,
                                backgroundColor: ['#ffbc3b', '#28a745', '#dc3545', '#17a2b8', '#6c757d'],
                                hoverOffset: 4,
                                borderWidth: 2,
                                borderColor: '#ffffff'
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            cutout: '70%'
                        }
                    });
                }
            } catch(e) { console.error("Error init bourse chart:", e); }
        }

        // Event Type Chart
        var eventCanvas = document.getElementById('eventTypeChart');
        if (eventCanvas && !eventTypeChartInstance) {
            try {
                var eData = {{ (fullStats.events.chartData ?? {labels:[], data:[]})|json_encode|raw }};
                if (eData.labels.length > 0) {
                    eventTypeChartInstance = new Chart(eventCanvas, {
                        type: 'bar',
                        data: {
                            labels: eData.labels,
                            datasets: [{
                                label: 'Nombre d\'événements',
                                data: eData.data,
                                backgroundColor: '#ffbc3b',
                                borderRadius: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: { beginAtZero: true, grid: { display: false }, ticks: { stepSize: 1 } },
                                x: { grid: { display: false } }
                            },
                            plugins: {
                                legend: { display: false }
                            }
                        }
                    });
                }
            } catch(e) { console.error("Error init event chart:", e); }
        }
    }
    
    // Show/hide sections
    function showSection(sectionName, evt) {
        // Hide all sections
        var sections = document.querySelectorAll('.content-section');
        sections.forEach(function(section) {
            section.style.display = 'none';
        });
        
        // Show selected section
        var selectedSection = document.getElementById('section-' + sectionName);
        if (selectedSection) {
            selectedSection.style.display = 'block';
            
            // Re-trigger chart resize if section is 'stats'
            if (sectionName === 'stats') {
                if (typeof initStatsCharts === 'function') {
                    initStatsCharts();
                }
                setTimeout(() => window.dispatchEvent(new Event('resize')), 100);
            }
        }
        
        // Update active menu item
        document.querySelectorAll('.sidebar-menu a').forEach(function(link) {
            link.classList.remove('active');
        });
        
        if (evt && evt.target) {
            var clickedLink = evt.target.closest('a');
            if (clickedLink) {
                clickedLink.classList.add('active');
            }
        }
    }

    // Toggle sidebar
    function toggleSidebar() {
        var sidebar = document.getElementById('adminSidebar');
        var content = document.getElementById('adminContent');
        
        if (sidebar) sidebar.classList.toggle('collapsed');
        if (content) content.classList.toggle('expanded');
    }

    // Toggle mobile sidebar
    function toggleMobileSidebar() {
        var sidebar = document.getElementById('adminSidebar');
        if (sidebar) sidebar.classList.toggle('mobile-open');
    }

    // Filter quiz by type
    function filterQuiz(type, evt) {
        var quizItems = document.querySelectorAll('.quiz-item');
        var buttons = document.querySelectorAll('.btn-group button');
        
        buttons.forEach(function(btn) {
            btn.classList.remove('active');
        });
        
        if (evt && evt.target) {
            evt.target.classList.add('active');
        }
        
        quizItems.forEach(function(item) {
            var itemType = item.getAttribute('data-type');
            if (type === 'all' || itemType === type.toLowerCase()) {
                item.style.display = 'block';
            } else {
                item.style.display = 'none';
            }
        });
    }

    // Initialize on page load
    window.addEventListener('DOMContentLoaded', function() {
        // Check URL hash
        var hash = window.location.hash.substring(1);
        if (hash) {
            showSection(hash);
        } else {
            var urlParams = new URLSearchParams(window.location.search);
            var section = urlParams.get('section');
            if (section) {
                showSection(section);
            } else {
                showSection('dashboard');
            }
        }
        
        // Initialize chart ONCE
        var chartCanvas = document.getElementById('registrationsChart');
        if (chartCanvas && !registrationsChartInstance) {
            var chartData = {{ chartData|json_encode|raw }};
            
            registrationsChartInstance = new Chart(chartCanvas, {
                type: 'line',
                data: chartData,
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });
        }

        // Initialize stats charts if we are on the stats section
        if (hash === 'stats' || (new URLSearchParams(window.location.search)).get('section') === 'stats') {
            initStatsCharts();
        }
    });
    
    function confirmDelete(userId) {
        if(confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?')) {
            window.location.href = "#";
        }
    }
    
    function editCourse(id, titre, niveau, matiere, langue, description) {
        var form = document.getElementById('editCourseForm');
        if (form) {
            form.action = '/admin/course/' + id + '/update';
        }
        
        document.getElementById('edit_titre_cours').value = titre;
        document.getElementById('edit_niv_cours').value = niveau;
        document.getElementById('edit_matiere_cours').value = matiere;
        document.getElementById('edit_langue_cours').value = langue;
        document.getElementById('edit_description').value = description || '';
        
        if (typeof $ !== 'undefined' && $.fn.modal) {
            $('#editCourseModal').modal('show');
        }
    }
    </script>
{% endblock %}