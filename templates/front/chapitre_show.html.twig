
{% extends 'base.html.twig' %}

{% block title %}{{ chapitre.titreChap }}{% endblock %}

{% block body %}
<div class="container" style="margin-top: 30px;">
    <h1>{{ chapitre.titreChap }}</h1>
    <p><strong>Description :</strong> {{ chapitre.descChap }}</p>

    <hr>

    {% if chapitre.typeContenu == 'pdf' %}
        {# Affiche le PDF dans un iframe #}
        <iframe src="{{ asset('uploads/' ~ chapitre.contenuChap) }}" 
                width="100%" height="600px">
            Votre navigateur ne supporte pas l'affichage du PDF.
        </iframe>

        {# Lien alternatif pour ouvrir le PDF #}
        <p><a href="{{ asset('uploads/' ~ chapitre.contenuChap) }}" target="_blank">
            Ouvrir le PDF dans une nouvelle fenêtre
        </a></p>

    {% elseif chapitre.typeContenu == 'video' %}
        <video controls width="100%" style="max-height:600px;">
            <source src="{{ asset('uploads/' ~ chapitre.contenuChap) }}" type="video/mp4">
            Votre navigateur ne supporte pas la lecture de cette vidéo.
        </video>
    {% else %}
        <p>Contenu non disponible.</p>
    {% endif %}
</div>

{% endblock %}
