{% extends 'front/formateur.html.twig' %}

{% block title %}Cours{% endblock %}

{% block body %}
    <h1>Cours</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ cour.id }}</td>
            </tr>
            <tr>
                <th>Titre_cours</th>
                <td>{{ cour.titreCours }}</td>
            </tr>
            <tr>
                <th>Desc_cours</th>
                <td>{{ cour.descCours }}</td>
            </tr>
            <tr>
                <th>Niv_cours</th>
                <td>{{ cour.nivCours }}</td>
            </tr>
            <tr>
                <th>Matiere_cours</th>
                <td>{{ cour.matiereCours }}</td>
            </tr>
            <tr>
                <th>Langue_cours</th>
                <td>{{ cour.langueCours }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('front_cours_index') }}">back to list</a>

    <a href="{{ path('front_cours_edit', {'id': cour.id}) }}">edit</a>

    {{ include('front/cours/_delete_form.html.twig') }}
{% endblock %}
