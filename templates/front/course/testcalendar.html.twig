{# templates/front/course/testcalendar.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Calendrier Test</title>
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.css" rel="stylesheet">
    <style>
        #calendar {
            max-width: 900px;
            margin: 50px auto;
            min-height: 700px;
            border: 1px solid #ccc;
        }
    </style>
</head>
<body>
    <h2>Calendrier Test</h2>
    <div id="calendar"></div>

    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var calendarEl = document.getElementById('calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'fr',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                events: [
                    { title: 'Test 1', start: '2026-02-09', color: 'blue' },
                    { title: 'Test 2', start: '2026-02-10', color: 'orange' },
                    { title: 'Test 3', start: '2026-02-11', color: 'green' }
                ]
            });
            calendar.render();
        });
    </script>
</body>
</html>
