{% extends 'base.html.twig' %}

{% block title %}Connexion - Educenter{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- Custom Login Styles -->
    <link href="{{ asset('css/style.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
<!-- page title -->
<section class="page-title-section overlay" data-background="{{ asset('images/backgrounds/page-title.jpg') }}">
  <div class="container">
    <div class="row">
      <div class="col-md-8">
        <ul class="list-inline custom-breadcrumb">
          <li class="list-inline-item"><a class="h2 text-primary font-secondary" >Accueil</a></li>
          <li class="list-inline-item text-white h3 font-secondary nasted">Connexion</li>
        </ul>
        <p class="text-lighten">Connectez-vous à votre compte pour continuer votre apprentissage</p>
      </div>
    </div>
  </div>
</section>
<!-- /page title -->

<!-- login section -->
<section class="section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6">
        <div class="login-container">
          <div class="login-card">
            <div class="text-center mb-4">
              <h2 class="mb-2">Bienvenue !</h2>
              <p class="text-muted">Connectez-vous pour accéder à votre tableau de bord</p>
            </div>

            {% if error %}
              <div class="alert alert-danger">
                {{ error.messageKey|trans(error.messageData, 'security') }}
              </div>
            {% endif %}

            <form action="{{ path('app_login') }}" method="post">
              <div class="form-group">
                <label for="email" class="font-weight-bold">Adresse Email</label>
                <input type="email" class="form-control" id="email" name="_username" value="{{ last_username }}" placeholder="votre@email.com" required autofocus>
              </div>

              <div class="form-group form-group-password">
                <label for="password" class="font-weight-bold">Mot de passe</label>
                <input type="password" class="form-control" id="password" name="_password" placeholder="Votre mot de passe" required>
                <i class="ti-eye password-toggle" id="togglePassword"></i>
              </div>

              <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

              <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="rememberMe" name="_remember_me">
                  <label class="form-check-label" for="rememberMe">
                    Se souvenir de moi
                  </label>
                </div>
                <a href="{{ path('app_forgot_password') }}" class="text-primary">Mot de passe oublié ?</a>
              </div>

              <button type="submit" class="btn btn-login btn-block text-white">
                <i class="ti-lock mr-2"></i>Se Connecter
              </button>
            </form>

            <div class="divider">
              <span>OU</span>
            </div>

            <button class="btn btn-block social-login-btn">
              <i class="ti-google"></i>Continuer avec Google
            </button>

            <button class="btn btn-block social-login-btn">
              <i class="ti-facebook"></i>Continuer avec Facebook
            </button>

            <div class="text-center mt-4">
              <p class="mb-0">Vous n'avez pas de compte ? <a href="{{ path('app_register') }}" class="text-primary font-weight-bold">Inscrivez-vous</a></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


{% block javascripts %}
    {{ parent() }}
    <!-- Custom Login Script -->
    <script src="{{ asset('js/script.js') }}"></script>
{% endblock %}

{% if app.user %}
    <div class="alert alert-success text-center">
        ✅ Vous êtes connecté en tant que <strong>{{ app.user.email }}</strong>!
        <a href="{{ path('app_logout') }}" class="btn btn-sm btn-danger ml-3">Se déconnecter</a>
    </div>
{% endif %}
<!-- /login section -->
{% endblock %}

