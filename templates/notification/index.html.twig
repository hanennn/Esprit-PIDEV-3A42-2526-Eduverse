{% extends 'base.html.twig' %}

{% block title %}Notifications{% endblock %}

{% block body %}
<div style="margin-top: 200px; margin-left: auto; margin-right: auto; max-width: 1000px;">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1><i class="ti-bell"></i> Mes Notifications</h1>
        <div>
            <a href="{{ path('app_forum_index') }}" class="btn btn-outline-secondary mr-2">
                <i class="ti-arrow-left"></i> Retour au Forum
            </a>
            {% if unreadCount > 0 %}
                <button id="markAllReadBtn" class="btn btn-outline-primary">
                    <i class="ti-check"></i> Marquer tout comme lu
                </button>
            {% endif %}
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    {% endfor %}

    {% if notifications is empty %}
        <div class="alert alert-info">
            <i class="ti-info-alt"></i> Vous n'avez aucune notification pour le moment.
        </div>
    {% else %}
        <div class="list-group">
            {% for notification in notifications %}
                <div class="list-group-item {% if not notification.isRead %}list-group-item-light border-primary{% endif %} notification-item" data-notification-id="{{ notification.id }}">
                    <div class="d-flex w-100 justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            {% if notification.type == 'new_forum' %}
                                <span class="badge badge-info mr-2"><i class="ti-announcement"></i> Nouveau Forum</span>
                            {% elseif notification.type == 'new_comment' %}
                                <span class="badge badge-success mr-2"><i class="ti-comment"></i> Nouveau Commentaire</span>
                            {% elseif notification.type == 'comment_deleted' %}
                                <span class="badge badge-warning mr-2"><i class="ti-trash"></i> Commentaire Supprimé</span>
                            {% endif %}
                            
                            {% if not notification.isRead %}
                                <span class="badge badge-primary">Nouveau</span>
                            {% endif %}
                            
                            <p class="mb-1 mt-2">{{ notification.message }}</p>
                            
                            <small class="text-muted">
                                <i class="ti-time"></i> {{ notification.dateCreation|date('d/m/Y H:i') }}
                            </small>
                        </div>
                        
                        <div class="ml-3 d-flex flex-column">
                            {% if notification.sujet %}
                                <a href="{{ path('app_forum_show', {'id': notification.sujet.id}) }}" class="btn btn-sm btn-outline-primary mb-2">
                                    <i class="ti-eye"></i> Voir
                                </a>
                            {% endif %}
                            
                            {% if not notification.isRead %}
                                <button class="btn btn-sm btn-outline-success mb-2 mark-read-btn" data-id="{{ notification.id }}">
                                    <i class="ti-check"></i> Lu
                                </button>
                            {% endif %}
                            
                            <form method="post" action="{{ path('app_notification_delete', {'id': notification.id}) }}" style="display:inline-block;" onsubmit="return confirm('Supprimer cette notification?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ notification.id) }}">
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="ti-trash"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<style>
    .notification-item {
        transition: all 0.3s ease;
    }
    .notification-item:not(.list-group-item-light) {
        opacity: 0.7;
    }
    .notification-item:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Mark individual notification as read
    document.querySelectorAll('.mark-read-btn').forEach(button => {
        button.addEventListener('click', function() {
            const notificationId = this.getAttribute('data-id');
            fetch(`/notification/${notificationId}/read`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            }).then(response => response.json())
              .then(data => {
                  if (data.success) {
                      const item = this.closest('.notification-item');
                      item.classList.remove('list-group-item-light', 'border-primary');
                      item.querySelector('.badge-primary')?.remove();
                      this.remove();
                      
                      // Update count in page
                      location.reload();
                  }
              });
        });
    });
    
    // Mark all as read
    const markAllBtn = document.getElementById('markAllReadBtn');
    if (markAllBtn) {
        markAllBtn.addEventListener('click', function() {
            fetch('/notification/mark-all-read', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            }).then(response => response.json())
              .then(data => {
                  if (data.success) {
                      location.reload();
                  }
              });
        });
    }
});
</script>
{% endblock %}
