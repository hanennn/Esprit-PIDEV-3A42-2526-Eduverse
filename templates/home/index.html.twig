{% extends 'base.html.twig' %}

{% block title %}Bienvenue - Eduverse{% endblock %}

{% block body %}
<div style="margin: 50px auto; max-width: 800px; text-align: center;">
    <h1>Bienvenue sur Eduverse! 🎓</h1>
    
    <div style="margin-top: 30px;">
        <p>Votre plateforme éducative complète</p>
    </div>

    <div style="margin-top: 50px; display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
        <a href="{{ path('app_bourse_list') }}" class="btn btn-primary">Voir les Bourses</a>
        <a href="{{ path('app_event_list') }}" class="btn btn-info">Voir les Événements</a>
        <a href="{{ path('app_login') }}" class="btn btn-success">Se Connecter</a>
        <a href="{{ path('app_register') }}" class="btn btn-warning">S'inscrire</a>
    </div>

    <div style="margin-top: 50px;">
        <h2>Fonctionnalités</h2>
        <ul style="list-style: none; padding: 0;">
            <li>📚 Gestion des Cours et Chapitres</li>
            <li>💰 Bourses d'études</li>
            <li>📅 Événements académiques</li>
            <li>✅ Quiz et Questions</li>
            <li>👥 Gestion des Utilisateurs</li>
        </ul>
    </div>
</div>
{% endblock %}
