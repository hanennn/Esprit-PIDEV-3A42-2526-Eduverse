# ── EduVerse Interview IA Microservice Config ──

# Whisper model size: tiny, base, small, medium, large
# "small" is recommended for CPU, "medium" for GPU (4GB+ VRAM)
WHISPER_MODEL=small

# Path to the fine-tuned CamemBERT emotion model
EMOTION_MODEL_PATH=./mon_modele_bourse

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
